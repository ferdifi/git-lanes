#!/bin/bash
# git-lanes PostToolUse hook for Claude Code
# Auto-tracks files after Write/Edit operations

TOOL_NAME="$1"
FILE_PATH="$2"

case "$TOOL_NAME" in
  Write|Edit|MultiEdit)
    if [ -n "$FILE_PATH" ] && git lanes which > /dev/null 2>&1; then
      git lanes track "$FILE_PATH" 2>/dev/null || true
    fi
    ;;
esac

exit 0
